ntityPreffix":"%","entitySuffix":"%"},"rules":{}},"nlgManager":{"settings":{"tag":"nlg-manager"},"responses":{"en":{"greetings.hello":[{"answer":"Hey {{name}}! 😊 Really glad you're here. What's on your mind today?"},{"answer":"Hi {{name}}! 💙 I was literally just thinking — how's your day treating you?"}],"greetings.howareyou":[{"answer":"I'm doing great, thanks for checking on me 🥺💙 But really, how are *you* doing?"},{"answer":"Honestly? Living my best life listening to you 😄 More importantly — how are *you*, {{name}}?"}],"emotion.stress":[{"answer":"Ugh, stress is THE worst and I hate that for you 😔 What's been piling up lately? Maybe we can break it down together."},{"answer":"Hey {{name}}, breathe. Seriously — in... and out. 🌬️ You've handled hard things before. What's the biggest thing stressing you right now?"}],"emotion.sad":[{"answer":"I'm sorry you're going through this 💙 Sadness can feel incredibly heavy. You're not alone — I'm right here. What happened?"},{"answer":"{{name}}, I hear you. It's okay to not be okay 🤍 Can you tell me what's been bringing you down?"}],"school.exams":[{"answer":"Okay 📚 academic pressure is relentless. Let's not look at the whole pile — what's the single most urgent thing right now?"},{"answer":"You are MORE than your grades, {{name}}. I need you to really hear that 💙 But let's tackle this. What's stressing you most — content, time, or motivation?"}],"None":[{"answer":"Tell me more about that 👂 I want to fully understand what's going on for you, {{name}}."},{"answer":"That's really interesting — how does that make you feel overall? 🌟"},{"answer":"Hmm, that sounds like there might be more to unpack 🤔 What else is on your mind?"}]}}},"actionManager":{"settings":{"tag":"action-manager"},"actions":{}},"slotManager":{}}